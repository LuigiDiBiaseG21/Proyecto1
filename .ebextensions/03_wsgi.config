files:
  "/var/app/current/wsgi.py":
    mode: "000644"
    owner: root
    group: root
    content: |
      import os
      import sys
      
      # Add the current directory to path
      sys.path.insert(0, os.path.dirname(__file__))
      
      from application import application
      
      if __name__ == "__main__":
          application.run()
